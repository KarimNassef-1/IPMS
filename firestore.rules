rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDocExists() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDocExists()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function isAdmin() {
      return isSignedIn() && (
        userRole() == 'admin' ||
        (request.auth.token.role is string && request.auth.token.role == 'admin')
      );
    }

    function isPartner() {
      return isSignedIn() && (
        userRole() == 'partner' ||
        (request.auth.token.role is string && request.auth.token.role == 'partner')
      );
    }

    function isOutsource() {
      return isSignedIn() && (
        userRole() == 'outsource' ||
        (request.auth.token.role is string && request.auth.token.role == 'outsource')
      );
    }

    function isClient() {
      return isSignedIn() && userRole() == 'client';
    }

    function isAdminOrPartner() {
      return isAdmin() || isPartner();
    }

    function containsUid(values) {
      return values is list && request.auth.uid in values;
    }

    function containsValue(values, value) {
      return values is list && value in values;
    }

    function currentUserEmail() {
      return userDocExists() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email is string
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email
        : (
          request.auth.token.email is string
            ? request.auth.token.email
            : ''
        );
    }

    function currentUserName() {
      return userDocExists() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name is string
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name
        : '';
    }

    function isClientProject(data) {
      return isClient() && (
        data.clientUserId == request.auth.uid ||
        containsUid(data.clientUserIds) ||
        data.clientEmail == currentUserEmail() ||
        containsValue(data.clientEmails, currentUserEmail()) ||
        data.clientName == currentUserName()
      );
    }

    // Direct grant: a {uid}_{projectId} doc exists for this user.
    function hasClientProjectGrant(projectId) {
      return isSignedIn() &&
        projectId is string &&
        exists(/databases/$(database)/documents/client_project_access/$(request.auth.uid + '_' + projectId));
    }

    function canReadProjectForPortal(projectId) {
      return projectId is string && (
        hasClientProjectGrant(projectId) ||
        (
          isClient() &&
          exists(/databases/$(database)/documents/projects/$(projectId)) &&
          isClientProject(get(/databases/$(database)/documents/projects/$(projectId)).data)
        )
      );
    }

    function isPortalOwner(clientId) {
      return isSignedIn() &&
        clientId is string &&
        clientId == request.auth.uid;
    }

    function isAssignedOutsourcePortalUser(data) {
      return isSignedIn() && (
        data.assignedUserId == request.auth.uid ||
        containsUid(data.assignedUserIds)
      );
    }

    function isTaskAssignedToCurrentUser(taskData) {
      return isSignedIn() && (
        containsUid(taskData.assignedUserIds) ||
        taskData.assignedToUserId == request.auth.uid
      );
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() || (
        isOwner(userId) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.accountStatus == resource.data.accountStatus &&
        request.resource.data.teamIds == resource.data.teamIds &&
        request.resource.data.outsourceServices == resource.data.outsourceServices &&
        request.resource.data.websiteTracks == resource.data.websiteTracks &&
        request.resource.data.passwordResetRequired == false &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'photoURL',
          'email',
          'passwordResetRequired',
          'updatedAt'
        ])
      );
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /role_permissions/{roleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /projects/{projectId} {
      // Use resource.data directly to avoid redundant get() calls that exhaust
      // the Firestore rules external-read budget during collection queries.
      allow read: if isAdminOrPartner()
        || hasClientProjectGrant(projectId)
        || isClientProject(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if isAdminOrPartner() || canReadProjectForPortal(resource.data.projectId);
      allow create, update, delete: if isAdmin();
    }

    match /client_project_access/{accessId} {
      // Direct owner OR the named real client linked from an anonymous QR scan.
      allow read: if isAdminOrPartner() ||
        isPortalOwner(resource.data.clientId) ||
        (isSignedIn() && resource.data.linkedClientUserId == request.auth.uid);
      // Allow admins to provision grants, or the grant owner to create their own.
      allow create: if isAdminOrPartner() || isPortalOwner(request.resource.data.clientId);
      // Allow the linked real client to update (used to re-assign grant to real uid).
      allow update: if isAdminOrPartner() ||
        (isSignedIn() && resource.data.linkedClientUserId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'clientId', 'clientEmail', 'clientName', 'updatedAt'
         ]));
      allow delete: if isAdminOrPartner();
    }

    match /client_portal_qr_tokens/{tokenId} {
      // Only admins can list all tokens. Signed-in users can only read a known token doc.
      allow list: if isAdmin();
      allow get: if isAdmin() || (
        isSignedIn() &&
        resource.data.active == true
      );
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.active == true &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'consumedCount',
          'active',
          'lastConsumedAt',
          'lastConsumedByUserId',
          'lastConsumedByEmail',
          'updatedAt'
        ]) &&
        request.resource.data.consumedCount == resource.data.consumedCount + 1 &&
        request.resource.data.lastConsumedByUserId == request.auth.uid &&
        request.resource.data.lastConsumedAt is string &&
        request.resource.data.updatedAt is string &&
        (
          (request.auth.token.email is string && request.resource.data.lastConsumedByEmail == request.auth.token.email) ||
          (!(request.auth.token.email is string) && request.resource.data.lastConsumedByEmail == '')
        )
      );
    }

    match /client_tickets/{ticketId} {
      allow read: if isAdminOrPartner() || isOutsource() || isPortalOwner(resource.data.clientId);
      allow create: if isPortalOwner(request.resource.data.clientId);
      allow update: if isAdminOrPartner() || (
        isOutsource() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'updatedAt'
        ]) &&
        request.resource.data.status in ['open', 'resolved', 'closed'] &&
        request.resource.data.updatedAt is string
      );
      allow delete: if isAdminOrPartner();
    }

    match /outsource_portals/{portalId} {
      allow read: if isAdmin() || isPartner() || isOutsource();
      allow create, delete: if isAdmin();

      // Assigned outsource users can update progress/task content only.
      // Assignment and project/service linkage remain immutable for non-supervisors.
      allow update: if isAdmin() || isPartner() || (
        isAssignedOutsourcePortalUser(resource.data) &&
        isAssignedOutsourcePortalUser(request.resource.data) &&
        request.resource.data.assignedUserId == resource.data.assignedUserId &&
        request.resource.data.assignedUserIds == resource.data.assignedUserIds &&
        request.resource.data.projectId == resource.data.projectId &&
        request.resource.data.serviceId == resource.data.serviceId
      );
    }

    match /safe_codes/{codeId} {
      allow read: if isAdmin() || (
        isSignedIn() &&
        userRole() == 'outsource' &&
        codeId == 'active'
      );
      allow create, update, delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isAdminOrPartner();
      allow create: if isAdmin() || (isPartner() && isTaskAssignedToCurrentUser(request.resource.data));
      allow update: if isAdmin() || (
        isPartner() &&
        isTaskAssignedToCurrentUser(resource.data) &&
        request.resource.data.locked == resource.data.locked
      );
      allow delete: if isAdmin() || (
        isPartner() &&
        isTaskAssignedToCurrentUser(resource.data) &&
        resource.data.locked != true
      );
    }

    match /daily_tasks/{taskId} {
      allow read: if isAdminOrPartner();
      allow create, update: if isAdminOrPartner();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAdminOrPartner();
      allow create, update, delete: if isAdmin();
    }

    match /budgets/{budgetId} {
      allow read: if isAdminOrPartner();
      allow create, update, delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isAdminOrPartner();
      allow create, update: if isAdminOrPartner();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        (isAdmin() && resource.data.adminFeed == true)
      );
      allow create: if isAdminOrPartner() || (
        isSignedIn() && request.resource.data.actorId == request.auth.uid
      ) || (
        isOutsource() &&
        request.resource.data.action in [
          'client-ticket-status-updated',
          'outsource-task-status',
          'outsource-task-blocked-toggle'
        ] &&
        request.resource.data.userId is string &&
        request.resource.data.date is string
      );
      allow update, delete: if isAdmin();
    }

    match /auth_cleanup_requests/{requestId} {
      // Team user removal path enqueues cleanup work; worker processes it server-side.
      allow read, create, update, delete: if isAdmin();
    }

  }
}
