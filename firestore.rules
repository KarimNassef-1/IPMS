rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isPartner() {
      return isSignedIn() && userRole() == 'partner';
    }

    function isAdminOrPartner() {
      return isAdmin() || isPartner();
    }

    function containsUid(values) {
      return values is list && request.auth.uid in values;
    }

    function isAssignedOutsourcePortalUser(data) {
      return isSignedIn() && (
        containsUid(data.assignedUserIds) ||
        data.assignedUserId == request.auth.uid
      );
    }

    function isTaskAssignedToCurrentUser(taskData) {
      return isSignedIn() && (
        containsUid(taskData.assignedUserIds) ||
        taskData.assignedToUserId == request.auth.uid
      );
    }

    match /users/{userId} {
      // Always allow users to read their own profile doc so role lookup can succeed.
      allow read: if isOwner(userId) || isAdmin();

      // Users can create their own profile doc, and admins can create managed user docs.
      allow create: if isOwner(userId) || isAdmin();

      // Only admin can delete users docs.
      allow delete: if isAdmin();

      // Role changes must be admin-controlled only.
      allow update: if isAdmin() || (
        isOwner(userId) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.accountStatus == resource.data.accountStatus &&
        request.resource.data.teamIds == resource.data.teamIds &&
        request.resource.data.outsourceServices == resource.data.outsourceServices &&
        request.resource.data.websiteTracks == resource.data.websiteTracks &&
        request.resource.data.passwordResetRequired == false &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'photoURL',
          'email',
          'passwordResetRequired',
          'updatedAt'
        ])
      );
    }

    match /teams/{teamId} {
      // All signed-in users can read teams so service-scoped access can be resolved client-side.
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /role_permissions/{roleId} {
      // Clients subscribe to role permissions to drive page/module visibility.
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isAdminOrPartner();
      allow create, update, delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if isAdminOrPartner();
      allow create, update, delete: if isAdmin();
    }

    match /outsource_portals/{portalId} {
      allow read: if isAdmin() || isPartner() || isAssignedOutsourcePortalUser(resource.data);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isPartner() || (
        isAssignedOutsourcePortalUser(resource.data) &&
        request.resource.data.assignedUserIds == resource.data.assignedUserIds &&
        request.resource.data.projectId == resource.data.projectId &&
        request.resource.data.serviceId == resource.data.serviceId
      );
    }

    match /safe_codes/{codeId} {
      allow read: if isAdmin() || (
        isSignedIn() &&
        userRole() == 'outsource' &&
        codeId == 'active'
      );
      allow create, update, delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isAdminOrPartner();
      allow create: if isAdmin() || (isPartner() && isTaskAssignedToCurrentUser(request.resource.data));
      allow update: if isAdmin() || (
        isPartner() &&
        isTaskAssignedToCurrentUser(resource.data) &&
        request.resource.data.locked == resource.data.locked
      );
      allow delete: if isAdmin() || (
        isPartner() &&
        isTaskAssignedToCurrentUser(resource.data) &&
        resource.data.locked != true
      );
    }

    match /daily_tasks/{taskId} {
      allow read: if isAdminOrPartner();
      allow create, update: if isAdminOrPartner();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAdminOrPartner();
      allow create, update, delete: if isAdmin();
    }

    match /budgets/{budgetId} {
      allow read: if isAdminOrPartner();
      allow create, update, delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isAdminOrPartner();
      allow create, update: if isAdminOrPartner();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        (isAdmin() && resource.data.adminFeed == true)
      );
      allow create: if isAdminOrPartner() || (
        isSignedIn() && request.resource.data.actorId == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    match /custom_pages/{pageId} {
      allow read: if isAdminOrPartner();
      allow create, update, delete: if isAdmin();
    }
  }
}
